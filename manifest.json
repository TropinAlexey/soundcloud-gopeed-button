{
  "manifest_version": 3,
  "name": "SoundCloud → Gopeed",
  "version": "1.0.0",
  "description": "Adds a download button to SoundCloud tracks and playlists, sending them to Gopeed",
  "permissions": [
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://soundcloud.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://soundcloud.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SoundCloud → Gopeed"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
